{
  "name": "matchgorithm",
  "type": "javascript",
  "main": "functions/[[path]].ts",
  "compatibility_date": "2024-12-01",
  "env": {
    "production": {
      "routes": [
        {
          "pattern": "matchgorithm.co.uk",
          "zone_name": "matchgorithm.co.uk"
        }
      ]
    }
  },
  "build": {
    "command": "npm run build",
    "cwd": "./.",
    "watch_paths": ["src/**/*.ts"]
  },
  "build_output": {
    "format": "service-worker"
  }
}
