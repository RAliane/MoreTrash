# Database configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=directus

# Directus database connection (use the same values from above)
DIRECTUS_DATABASE_URL=postgres://user:password@db:5432/directus

# N8N database connection
DB_TYPE=postgres
DB_POSTGRESDB=n8n
DB_POSTGRESUSER=n8nuser
DB_POSTGRESPASSWORD=n8npassword
DB_POSTGRESHOST=db

# Node.js application environment
NODE_ENV=production

# N8N environment variables (optional, based on your setup)
N8N_HOST=https://your-n8n-host.com
N8N_PORT=5678
