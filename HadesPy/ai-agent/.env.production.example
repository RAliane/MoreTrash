# =============================================================================
# Render Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in values from Render dashboard
# DO NOT commit .env.production to version control
# =============================================================================

# =============================================================================
# PostgreSQL Database (from ai-agent-postgres service)
# =============================================================================
# Connection string format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://ai_agent:<password>@<host>.render.com:5432/ai_agent

# Or use individual components:
PG_HOST=<host>.render.com
PG_PORT=5432
PG_DATABASE=ai_agent
PG_USER=ai_agent
PG_PASSWORD=<generated_password>

# =============================================================================
# Neo4j Graph Database (from ai-agent-neo4j private service)
# =============================================================================
# URI format: neo4j://host:port (for private service within Render network)
NEO4J_URI=neo4j://ai-agent-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<generated_password>

# =============================================================================
# Directus CMS (from ai-agent-directus service)
# =============================================================================
DIRECTUS_URL=https://ai-agent-directus.onrender.com
DIRECTUS_TOKEN=<static_token_from_directus>

# Directus Admin (for initial setup)
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=<secure_password>

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
LOG_LEVEL=info
DEBUG=false

# =============================================================================
# AI/LLM Configuration
# =============================================================================
# LLM Provider: ollama, openai, anthropic, etc.
LLM_PROVIDER=ollama
LLM_MODEL=llama2

# For OpenAI (if using instead of Ollama)
# OPENAI_API_KEY=sk-...

# For Anthropic (if using Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama Configuration (if using local/remote Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# =============================================================================
# Feature Flags
# =============================================================================
# Enable XGBoost ranking for course recommendations
USE_XGBOOST_RANKING=true

# Enable vector search
USE_VECTOR_SEARCH=true

# Enable graph-based recommendations
USE_GRAPH_RECOMMENDATIONS=true

# =============================================================================
# Security
# =============================================================================
# Generate a secure random string for session signing
SECRET_KEY=<generate_with_openssl_rand_base64_32>

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# External Services (if applicable)
# =============================================================================
# SendGrid for email notifications
# SENDGRID_API_KEY=SG.xxx

# S3-compatible storage for file uploads
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...
# AWS_REGION=us-east-1

# =============================================================================
# Monitoring & Logging
# =============================================================================
# Sentry for error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Datadog for APM (if using)
# DD_AGENT_HOST=localhost
# DD_AGENT_PORT=8126

# =============================================================================
# Performance Tuning
# =============================================================================
# Database connection pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Cache TTL in seconds
CACHE_TTL=300

# Vector search settings
VECTOR_DIMENSION=1536
VECTOR_INDEX_TYPE=hnsw

# =============================================================================
# Render-Specific Settings
# =============================================================================
# These are automatically set by Render, shown here for reference:
# PORT=10000  # Render assigns this automatically
# RENDER=true
# RENDER_SERVICE_NAME=ai-agent-api
