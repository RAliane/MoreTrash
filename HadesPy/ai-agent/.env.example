# ============================================
# AI Agent Full Stack - Environment Configuration
# ============================================

# Application
APP_NAME="AI-Agent-Directus-FastMCP-FullStack"
APP_VERSION="0.1.0"
APP_ENV="development"
DEBUG=false
LOG_LEVEL="INFO"

# FastAPI
FASTAPI_HOST="0.0.0.0"
FASTAPI_PORT=8000
FASTAPI_WORKERS=1
FASTAPI_RELOAD=true
METRICS_ENDPOINT="/metrics"

# FastMCP
FASTMCP_AGENT_ENDPOINT="/agent"
FASTMCP_AUTO_REGISTER_TOOLS=true

# Directus
DIRECTUS_URL="http://localhost:8055"
DIRECTUS_TOKEN=""
DIRECTUS_DATABASE="pg"
DIRECTUS_DATABASE_PATH="artifacts/data.db"
DIRECTUS_BOOTSTRAP_MODELS="artifacts/models.json"
DIRECTUS_AUTH_SOURCE_OF_TRUTH=true
DIRECTUS_ADMIN_EMAIL="admin@example.com"
DIRECTUS_ADMIN_PASSWORD=""  # Generate with: openssl rand -base64 32

# Directus-DB connection (PostgreSQL)
# Used by Directus CMS with pgvector extension
DB_HOST="localhost"
DB_PORT=5432
DB_DATABASE="directus"
DB_USER="directus"
DB_PASSWORD="directus"
DB_SSL="false"

# Cognee RAG
COGNEE_EMBEDDING_MODEL="all-MiniLM-L6-v2"
COGNEE_VECTOR_STORE="artifacts/embeddings.db"
COGNEE_AUTO_CONTEXT_WINDOW=true
COGNEE_SIMILARITY_THRESHOLD=0.7
COGNEE_MAX_RESULTS=10

# UI
UI_DEFAULT="gradio"
GRADIO_SERVER_NAME="0.0.0.0"
GRADIO_SERVER_PORT=7860
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS="0.0.0.0"

# External APIs
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
HUGGINGFACE_TOKEN=""

# Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"
SCRAPE_TARGETS="api.example.com/metrics"

# Security
SECRET_KEY="change-me-in-production-use-secure-random-string"
ALLOWED_HOSTS="localhost,127.0.0.1,0.0.0.0"
CORS_ORIGINS="http://localhost,http://localhost:3000,http://localhost:7860,http://localhost:8501"

# Security Hardening (Phase 9)
# Maximum query length to prevent DoS attacks
MAX_QUERY_LENGTH=10000

# Enable query validation for Cypher and SQL queries
ENABLE_QUERY_VALIDATION=true

# Allowed Cypher relationship types (comma-separated allowlist)
# Default: COMPLETED,PREREQUISITE,PREREQUISITE_FOR,PREREQUISITE_OF,SIMILAR_TO,INTERACTED,BELONGS_TO
ALLOWED_CYPHER_RELATIONSHIPS="COMPLETED,PREREQUISITE,PREREQUISITE_FOR,PREREQUISITE_OF,SIMILAR_TO,INTERACTED,BELONGS_TO"

# Webhook signature verification for Directus
# Set to true to verify webhook signatures
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION=false
# Secret key for webhook signature verification (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=""

# Podman / Docker
PODMAN_USE_SECRETS=true
PODMAN_NETWORK_EDGE="edge_net"
PODMAN_NETWORK_APP="app_net"
PODMAN_NETWORK_DB="db_net"

# Database (for future PostgreSQL support)
DATABASE_URL="sqlite:///artifacts/data.db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================
# CI/CD Configuration
# ============================================
# CI-specific settings (auto-set in CI environment)
CI=false
PYTEST_CURRENT_TEST=0

# CI Service Configuration (PostgreSQL)
CI_POSTGRES_HOST=postgres
CI_POSTGRES_PORT=5432
CI_POSTGRES_DB=test
CI_POSTGRES_USER=test
CI_POSTGRES_PASSWORD=test

# CI Service Configuration (Neo4j)
CI_NEO4J_URI=bolt://neo4j:7687
CI_NEO4J_USER=neo4j
CI_NEO4J_PASSWORD=test

# Determinism Test Configuration
DETERMINISM_TEST_ITERATIONS=10
DETERMINISM_STRICT_MODE=true
