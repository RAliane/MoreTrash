# FastAPI XGBoost Optimizer - Environment Configuration
# Copy this file to .env and update with your values

# ==========================================
# Application Configuration
# ==========================================

# Application settings
APP_NAME=FastAPI XGBoost Optimizer
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
SECRET_KEY=your-super-secret-key-here-change-in-production
JWT_SECRET=jwt-secret-key-for-tokens
ALLOWED_API_KEYS=key1,key2,key3
API_KEY_HEADER=X-API-Key

# ==========================================
# Database Configuration
# ==========================================

# PostgreSQL with PostGIS
DATABASE_URL=postgresql+asyncpg://optimizer_user:secure_password@localhost:5432/optimizer_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT=30

# PostGIS
POSTGIS_SRID=4326
POSTGIS_INDEX_TYPE=GIST

# Hasura GraphQL
HASURA_URL=http://localhost:8080/v1/graphql
HASURA_ADMIN_SECRET=hasura_admin_secret

# ==========================================
# Redis Configuration
# ==========================================

REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_DB=0

# ==========================================
# Machine Learning Configuration
# ==========================================

# XGBoost
XGBOOST_MODEL_PATH=./models/xgboost
XGBOOST_N_ESTIMATORS=100
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1
XGBOOST_SUBSAMPLE=0.8
XGBOOST_COLSAMPLE_BYTREE=0.8

# PyGAD Genetic Algorithm
PYGAD_POPULATION_SIZE=100
PYGAD_NUM_GENERATIONS=50
PYGAD_PARENT_SELECTION_TYPE=tournament
PYGAD_CROSSOVER_TYPE=single_point
PYGAD_MUTATION_TYPE=random
PYGAD_MUTATION_PERCENT_GENES=10.0

# Google OR-Tools
ORTOOLS_MAX_TIME=30
ORTOOLS_NUM_SEARCH_WORKERS=4
ORTOOLS_ENABLE_LNS=true

# ==========================================
# Optimization Configuration
# ==========================================

# Workflow
WORKFLOW_TIMEOUT=300
MICROTASK_RETRY_ATTEMPTS=3
MICROTASK_RETRY_DELAY=1

# Constraints
CONSTRAINT_VALIDATION_ENABLED=true
SPATIAL_CONSTRAINT_INDEX=true

# ==========================================
# Logging Configuration
# ==========================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/application.log

# ==========================================
# Monitoring Configuration
# ==========================================

METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true

# ==========================================
# Rate Limiting Configuration
# ==========================================

RATE_LIMIT=100/minute
RATE_LIMIT_BURST=10

# ==========================================
# CORS Configuration
# ==========================================

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# Security Configuration
# ==========================================

# Rate limiting
RATE_LIMIT=100/minute
RATE_LIMIT_BURST=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# External Services Configuration
# ==========================================

# PostgreSQL
POSTGRES_USER=optimizer_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=optimizer_db

# Redis
REDIS_PASSWORD=redis_password

# Hasura
HASURA_GRAPHQL_ADMIN_SECRET=hasura_admin_secret

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ==========================================
# Development Configuration
# ==========================================

# Development overrides
# DEBUG=true
# LOG_LEVEL=DEBUG
# LOG_FORMAT=text
# ENVIRONMENT=development