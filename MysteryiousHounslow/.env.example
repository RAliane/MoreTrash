# Matchgorithm Production Configuration
# WARNING: Never commit actual secrets to version control!
# Use Podman secrets or HashiCorp Vault for production values.

# Database (PostgreSQL 13) - Use Podman secrets in production
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=your_database_name
DATABASE_URL=your_database_connection_url

# Directus CMS - Use Podman secrets in production
DIRECTUS_URL=https://your-directus-domain.com
DIRECTUS_API_KEY=your_directus_api_key

# Hasura GraphQL - Use Podman secrets in production
HASURA_GRAPHQL_ENDPOINT=https://your-hasura-domain.com/v1/graphql
HASURA_ADMIN_SECRET=your_hasura_admin_secret

# JWT Configuration - Use Podman secrets in production
JWT_PRIVATE_KEY_PEM=your_jwt_private_key_pem
JWT_PUBLIC_KEY_PEM=your_jwt_public_key_pem

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-domain.com

# Feature Flags
FEATURE_AUTOMATION=true
FEATURE_ANALYTICS=true
FEATURE_AFFILIATE=false

# =================================================================
# SECURITY WARNING: The following values are placeholders only.
# In production, use Podman secrets or HashiCorp Vault.
# Never commit actual secrets to this file!
# =================================================================

# OAuth Providers (Configure as needed)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# AI Services (Configure as needed)
# GROQ_API_KEY=your_groq_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key

# Third-party Services (Configure as needed)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# HUNTER_IO_KEY=your_hunter_api_key
# APOLLO_IO_KEY=your_apollo_api_key
