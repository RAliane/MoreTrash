# FastAPI XGBoost Optimizer - Environment Configuration
# WARNING: This is an EXAMPLE file. Never commit actual secrets!
# Use Podman secrets or HashiCorp Vault for production values.

# ==========================================
# Application Configuration
# ==========================================

# Application settings
APP_NAME=FastAPI XGBoost Optimizer
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security - Use Podman secrets in production
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
ALLOWED_API_KEYS=key1,key2,key3
API_KEY_HEADER=X-API-Key

# ==========================================
# Database Configuration
# ==========================================

# Hasura GraphQL - Use Podman secrets in production
HASURA_URL=https://your-hasura-endpoint.com/v1/graphql
HASURA_ADMIN_SECRET=your_hasura_admin_secret

# Directus REST API - Use Podman secrets in production
DIRECTUS_URL=https://your-directus-endpoint.com
DIRECTUS_API_KEY=your_directus_api_key

# ==========================================
# Redis Configuration
# ==========================================

# Redis - Use Podman secrets for password
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_DB=0

# ==========================================
# Machine Learning Configuration
# ==========================================

# XGBoost
XGBOOST_MODEL_PATH=./models/xgboost
XGBOOST_N_ESTIMATORS=100
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1
XGBOOST_SUBSAMPLE=0.8
XGBOOST_COLSAMPLE_BYTREE=0.8

# PyGAD Genetic Algorithm
PYGAD_POPULATION_SIZE=100
PYGAD_NUM_GENERATIONS=50
PYGAD_PARENT_SELECTION_TYPE=tournament
PYGAD_CROSSOVER_TYPE=single_point
PYGAD_MUTATION_TYPE=random
PYGAD_MUTATION_PERCENT_GENES=10.0

# Google OR-Tools
ORTOOLS_MAX_TIME=30
ORTOOLS_NUM_SEARCH_WORKERS=4
ORTOOLS_ENABLE_LNS=true

# ==========================================
# Optimization Configuration
# ==========================================

# Workflow
WORKFLOW_TIMEOUT=300
MICROTASK_RETRY_ATTEMPTS=3
MICROTASK_RETRY_DELAY=1

# Constraints
CONSTRAINT_VALIDATION_ENABLED=true
SPATIAL_CONSTRAINT_INDEX=true

# ==========================================
# Logging Configuration
# ==========================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/application.log

# ==========================================
# Monitoring Configuration
# ==========================================

METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true

# ==========================================
# Rate Limiting Configuration
# ==========================================

RATE_LIMIT=100/minute
RATE_LIMIT_BURST=10

# ==========================================
# CORS Configuration
# ==========================================

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# Security Configuration
# ==========================================

# Rate limiting
RATE_LIMIT=100/minute
RATE_LIMIT_BURST=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# SECURITY NOTICE
# ==========================================
