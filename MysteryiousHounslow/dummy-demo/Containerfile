FROM rust:1.70-slim as builder

WORKDIR /app

# Copy Cargo.toml and src from the app directory
COPY app/Cargo.toml ./
COPY app/src/ ./src/

# Build the application
RUN cargo build --release

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/target/release/dummy-demo-web /app/dummy-demo-web

EXPOSE 3000

CMD ["./dummy-demo-web"]