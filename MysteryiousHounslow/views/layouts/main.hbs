<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#000000">
  <title>{{title}}</title>
  <meta name="description" content="Evolutionary algorithm-powered matching platform connecting professionals, talent, and opportunities with unprecedented accuracy.">
  
  <!-- Tailwind CSS -->
  <link rel="stylesheet" href="/css/styles.css">
  
  <!-- HTMX -->
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10/dist/ext/response-targets.js"></script>
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-background text-foreground antialiased">
  {{> header}}
  
  {{{body}}}
  
  {{> footer}}
  
  <script>
    // Initialize Lucide icons
    lucide.createIcons();
  </script>
</body>
</html>
